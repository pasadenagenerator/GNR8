{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "composite": true,
    "declaration": true,

    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true
  },
  "include": ["src"],
  "references": [
    { "path": "../core" }
  ]
}